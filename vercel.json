{
  "buildCommand": "prisma generate && next build",
  "devCommand": "next dev",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "nodejs": "18.x",
  "regions": ["iad1"],
  "env": [
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL",
    "NEXT_PUBLIC_API_BASE_URL",
    "DATABASE_URL"
  ]
}
