# Database
# Format: mysql://user:password@host:port/database
DATABASE_URL="mysql://username:password@localhost:3306/lumesbd?sslmode=disabled"

# NextAuth
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-secure-random-secret-here"

# NextAuth URL - should match your deployment domain
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# API Base URL
# Local: http://localhost:3001
# Production: https://your-api-domain.com or https://your-domain.com/api
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"

# Session Timeout (in minutes)
SESSION_EXPIRY_TIME=15

